<div class="custom-promo">
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.text }}</p>
  <p>{{ section.settings.text2 }}</p>
</div>

{% schema %}
{
  "name": "Custom Promo",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Special Offer"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Enter your promotional text here."
    },
    {
      "type": "textarea",
      "id": "text2",
      "label": "Text",
      "default": "Enter your promotional text here."
    }
  ],
  "presets": [
    {
      "name": "Custom Promo"
    }
  ]
}
{% endschema %}