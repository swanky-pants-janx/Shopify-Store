{%- comment -%}
  Filter Tabs — pill-style menu bar where each block is a tab.

  HOW IT LINKS TO OTHER SECTIONS:
  The sections placed DIRECTLY BELOW this one in the theme editor become
  the tab panels, in order. One tab = one section. Tab 1 shows the first
  section below, tab 2 the second, etc. Add as many tabs (blocks) as you
  have sections. Any section type works, including custom ones.
{%- endcomment -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="filter-tabs filter-tabs--{{ section.settings.menu_alignment }} filter-tabs--{{ section.settings.menu_size }}{% unless section.settings.show_border %} filter-tabs--no-border{% endunless %}{% if section.settings.accent_pill %} filter-tabs--accent{% endif %} section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
  id="filter-tabs-{{ section.id }}"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="filter-tabs__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="filter-tabs__bar" role="tablist">
    <span class="filter-tabs__pill" data-pill aria-hidden="true"></span>
    {%- for block in section.blocks -%}
      <button
        class="filter-btn{% if forloop.first %} active{% endif %}"
        type="button"
        role="tab"
        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        {{ block.shopify_attributes }}
      >
        {{ block.settings.title }}
      </button>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .filter-tabs {
    --rose: var(--color-primary);
    --text-mid: var(--color-foreground-muted);
    --white: var(--color-background);
    --pill-bg: var(--color-foreground);
    --tab-pad-y: 0.55rem;
    --tab-pad-x: 1.35rem;
    --tab-font-size: 0.68rem;
  }

  .filter-tabs--small {
    --tab-pad-y: 0.4rem;
    --tab-pad-x: 1rem;
    --tab-font-size: 0.6rem;
  }

  .filter-tabs--large {
    --tab-pad-y: 0.7rem;
    --tab-pad-x: 1.7rem;
    --tab-font-size: 0.8rem;
  }

  .filter-tabs--accent {
    --pill-bg: var(--color-primary);
    --white: var(--color-primary-button-text, var(--color-background));
  }

  .filter-tabs__heading {
    margin-block-end: 1.5rem;
  }

  /* The section lays children out in a grid that stretches items
     full-width by default; justify-self makes the bar hug its tabs. */
  .filter-tabs--left { text-align: left; }
  .filter-tabs--left .filter-tabs__bar { justify-self: start; }
  .filter-tabs--center { text-align: center; }
  .filter-tabs--center .filter-tabs__bar { justify-self: center; }
  .filter-tabs--right { text-align: right; }
  .filter-tabs--right .filter-tabs__bar { justify-self: end; }

  .filter-tabs__bar {
    position: relative;
    display: inline-flex;
    flex-wrap: nowrap;
    gap: 0.25rem;
    max-width: 100%;
    overflow-x: auto;
    padding: 0.3rem;
    border: 1px solid var(--color-border);
    border-radius: 50px;
    scrollbar-width: none;
  }

  .filter-tabs--no-border .filter-tabs__bar {
    border-color: transparent;
  }

  .filter-tabs__bar::-webkit-scrollbar {
    display: none;
  }

  .filter-tabs__pill {
    position: absolute;
    top: 0.3rem;
    left: 0;
    height: calc(100% - 0.6rem);
    background: var(--pill-bg);
    border-radius: 50px;
    transition: transform 0.3s ease, width 0.3s ease;
    will-change: transform, width;
  }

  .filter-btn {
    position: relative;
    z-index: 1;
    background: none;
    border: none;
    border-radius: 50px;
    padding: var(--tab-pad-y) var(--tab-pad-x);
    font-family: var(--font-body--family);
    font-size: var(--tab-font-size);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-mid);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .filter-btn:hover {
    color: var(--rose);
  }

  .filter-btn.active {
    color: var(--white);
  }

  .filter-tabs-panel--hidden {
    display: none !important;
  }

  .filter-tabs-panel--visible {
    animation: filter-tabs-fade-in 0.35s ease;
  }

  @keyframes filter-tabs-fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const TAB_COUNT = {{ section.blocks.size }};

    const init = () => {
      const section = document.getElementById('filter-tabs-{{ section.id }}');
      if (!section) return;

      const wrapper = section.closest('.shopify-section') || section;
      const pill = section.querySelector('[data-pill]');
      const buttons = [...section.querySelectorAll('.filter-btn')];

      // The sections immediately following this one are the tab panels
      const collectPanels = () => {
        const panels = [];
        let el = wrapper.nextElementSibling;
        while (el && panels.length < TAB_COUNT) {
          if (el.classList.contains('shopify-section')) panels.push(el);
          el = el.nextElementSibling;
        }
        return panels;
      };

      let panels = collectPanels();

      const movePill = (btn) => {
        pill.style.width = `${btn.offsetWidth}px`;
        pill.style.transform = `translateX(${btn.offsetLeft}px)`;
      };

      const activate = (index, animate = true) => {
        buttons.forEach((btn, i) => {
          const isActive = i === index;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-selected', isActive);
          if (isActive) movePill(btn);
        });
        panels.forEach((panel, i) => {
          panel.classList.toggle('filter-tabs-panel--hidden', i !== index);
          panel.classList.toggle('filter-tabs-panel--visible', animate && i === index);
        });
      };

      buttons.forEach((btn, i) => btn.addEventListener('click', () => activate(i)));

      const currentIndex = () => buttons.findIndex((btn) => btn.classList.contains('active'));

      const positionInitial = () => {
        const current = buttons[currentIndex()];
        if (current) {
          pill.style.transition = 'none';
          movePill(current);
          requestAnimationFrame(() => (pill.style.transition = ''));
        }
      };

      activate(Math.max(currentIndex(), 0), false);
      positionInitial();
      window.addEventListener('resize', positionInitial);
      if (document.fonts) document.fonts.ready.then(positionInitial);

      // Theme editor support: re-detect panels when sections are added,
      // removed, or reordered, and reveal a panel when it's selected.
      if (window.Shopify && window.Shopify.designMode) {
        const refresh = () => {
          panels.forEach((panel) =>
            panel.classList.remove('filter-tabs-panel--hidden', 'filter-tabs-panel--visible')
          );
          panels = collectPanels();
          activate(Math.max(currentIndex(), 0), false);
        };
        ['shopify:section:load', 'shopify:section:unload', 'shopify:section:reorder'].forEach((evt) =>
          document.addEventListener(evt, refresh)
        );
        document.addEventListener('shopify:section:select', (event) => {
          const index = panels.indexOf(event.target);
          if (index >= 0) activate(index, false);
        });
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{% schema %}
{
  "name": "Filter Tabs",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Each tab controls one of the sections placed directly below this one, in order: tab 1 shows the first section below, tab 2 the second, and so on."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "menu_alignment",
      "label": "Menu alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "menu_size",
      "label": "Menu size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show outer border",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "accent_pill",
      "label": "Use accent color for active tab",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Menu label",
          "default": "Tab"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Filter Tabs",
      "blocks": [
        { "type": "tab", "settings": { "title": "All" } },
        { "type": "tab", "settings": { "title": "New Arrivals" } },
        { "type": "tab", "settings": { "title": "Best Sellers" } }
      ]
    }
  ]
}
{% endschema %}
