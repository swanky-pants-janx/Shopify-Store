{%- comment -%}
  Filter Tabs — pill-style menu bar where each block is a tab.
  Clicking a pill swaps the visible content panel below (no page reload).
{%- endcomment -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="filter-tabs section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-filter-tabs
  id="filter-tabs-{{ section.id }}"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="filter-tabs__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="filter-tabs__bar" role="tablist">
    <span class="filter-tabs__pill" data-pill aria-hidden="true"></span>
    {%- for block in section.blocks -%}
      <button
        class="filter-btn{% if forloop.first %} active{% endif %}"
        type="button"
        role="tab"
        aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        aria-controls="panel-{{ section.id }}-{{ forloop.index }}"
        data-tab-index="{{ forloop.index }}"
        {{ block.shopify_attributes }}
      >
        {{ block.settings.title }}
      </button>
    {%- endfor -%}
  </div>

  {%- for block in section.blocks -%}
    <div
      class="filter-tabs__panel"
      id="panel-{{ section.id }}-{{ forloop.index }}"
      role="tabpanel"
      {% unless forloop.first %}hidden{% endunless %}
    >
      {%- if block.settings.image != blank -%}
        <div class="filter-tabs__image">
          {{ block.settings.image | image_url: width: 1500 | image_tag: widths: '750, 1100, 1500', loading: 'lazy' }}
        </div>
      {%- endif -%}
      {%- if block.settings.panel_heading != blank -%}
        <h3 class="filter-tabs__panel-heading">{{ block.settings.panel_heading }}</h3>
      {%- endif -%}
      {%- if block.settings.content != blank -%}
        <div class="filter-tabs__content rte">{{ block.settings.content }}</div>
      {%- endif -%}
      {%- if block.settings.page != blank -%}
        <div class="filter-tabs__content rte">{{ block.settings.page.content }}</div>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>

{% stylesheet %}
  .filter-tabs {
    --rose: var(--color-primary);
    --text-mid: var(--color-foreground-muted);
    --white: var(--color-background);
    --pill-bg: var(--color-foreground);
    text-align: center;
  }

  .filter-tabs__heading {
    margin-block-end: 1.5rem;
  }

  .filter-tabs__bar {
    position: relative;
    display: inline-flex;
    flex-wrap: nowrap;
    gap: 0.25rem;
    max-width: 100%;
    overflow-x: auto;
    padding: 0.3rem;
    border: 1px solid var(--color-border);
    border-radius: 50px;
    scrollbar-width: none;
  }

  .filter-tabs__bar::-webkit-scrollbar {
    display: none;
  }

  .filter-tabs__pill {
    position: absolute;
    top: 0.3rem;
    left: 0;
    height: calc(100% - 0.6rem);
    background: var(--pill-bg);
    border-radius: 50px;
    transition: transform 0.3s ease, width 0.3s ease;
    will-change: transform, width;
  }

  .filter-btn {
    position: relative;
    z-index: 1;
    background: none;
    border: none;
    border-radius: 50px;
    padding: 0.55rem 1.35rem;
    font-family: var(--font-body--family);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-mid);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.25s ease;
  }

  .filter-btn:hover {
    color: var(--rose);
  }

  .filter-btn.active {
    color: var(--white);
  }

  .filter-tabs__panel {
    margin-block-start: 2rem;
    animation: filter-tabs-fade-in 0.35s ease;
  }

  .filter-tabs__image img {
    max-width: 100%;
    height: auto;
    border-radius: var(--border-radius-sm, 8px);
    margin-block-end: 1.25rem;
  }

  .filter-tabs__content {
    max-width: 60rem;
    margin-inline: auto;
  }

  @keyframes filter-tabs-fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const section = document.getElementById('filter-tabs-{{ section.id }}');
    if (!section) return;

    const bar = section.querySelector('.filter-tabs__bar');
    const pill = section.querySelector('[data-pill]');
    const buttons = [...section.querySelectorAll('.filter-btn')];
    const panels = [...section.querySelectorAll('.filter-tabs__panel')];

    const movePill = (btn) => {
      pill.style.width = `${btn.offsetWidth}px`;
      pill.style.transform = `translateX(${btn.offsetLeft}px)`;
    };

    const activate = (index) => {
      buttons.forEach((btn, i) => {
        const isActive = i === index;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-selected', isActive);
        if (isActive) movePill(btn);
      });
      panels.forEach((panel, i) => {
        panel.hidden = i !== index;
      });
    };

    buttons.forEach((btn, i) => btn.addEventListener('click', () => activate(i)));

    const positionInitial = () => {
      const current = section.querySelector('.filter-btn.active');
      if (current) {
        pill.style.transition = 'none';
        movePill(current);
        requestAnimationFrame(() => (pill.style.transition = ''));
      }
    };

    positionInitial();
    window.addEventListener('resize', positionInitial);
    if (document.fonts) document.fonts.ready.then(positionInitial);

    // Theme editor: selecting a block in the sidebar shows its tab
    document.addEventListener('shopify:block:select', (event) => {
      const index = buttons.findIndex((btn) => btn.contains(event.target) || btn === event.target);
      if (index >= 0 && section.contains(event.target)) activate(index);
    });
  })();
</script>

{% schema %}
{
  "name": "Filter Tabs",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Menu label",
          "default": "Tab"
        },
        {
          "type": "text",
          "id": "panel_heading",
          "label": "Panel heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add your content for this tab here.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional)"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Or pull content from a page"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Filter Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "title": "All",
            "content": "<p>This is the first tab. Each tab is a block — edit the label and content in the sidebar.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "New Arrivals",
            "content": "<p>Content for the second tab goes here.</p>"
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "Best Sellers",
            "content": "<p>Content for the third tab goes here.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
