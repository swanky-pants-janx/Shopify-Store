{% doc %}
  @prompt
    I want a slideshow marquee for images
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-slideshow-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    position: relative;
    display: block;
    padding: {{ block.settings.vertical_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-marquee-slideshow-{{ ai_gen_id }}:hover .ai-marquee-track-{{ ai_gen_id }} {
    animation-play-state: {% if block.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  .ai-marquee-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width }}px;
    height: {{ block.settings.image_height }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-marquee-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-marquee-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-marquee-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-item-{{ ai_gen_id }} {
      width: {{ block.settings.image_width | times: 0.7 }}px;
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<marquee-slideshow-{{ ai_gen_id }}
  class="ai-marquee-slideshow-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-marquee-track-{{ ai_gen_id }}">
    {% liquid
      assign images_array = ''
      for i in (1..8)
        assign image_key = 'image_' | append: i
        assign current_image = block.settings[image_key]
        if current_image != blank
          assign images_array = images_array | append: i | append: ','
        endif
      endfor
      assign images_array = images_array | split: ','
      assign images_count = images_array.size
    %}

    {% if images_count > 0 %}
      {% for iteration in (1..2) %}
        {% for i in (1..8) %}
          {% assign image_key = 'image_' | append: i %}
          {% assign current_image = block.settings[image_key] %}
          {% if current_image != blank %}
            <div class="ai-marquee-item-{{ ai_gen_id }}">
              <img
                src="{{ current_image | image_url: width: 800 }}"
                alt="{{ current_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image_width }}"
                height="{{ block.settings.image_height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      {% endfor %}
    {% else %}
      {% for i in (1..6) %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">
          <div class="ai-marquee-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        </div>
      {% endfor %}
      {% for i in (1..6) %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">
          <div class="ai-marquee-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</marquee-slideshow-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Image marquee",
  "tag": null,
  "settings": [
    {
      "type": "header",
